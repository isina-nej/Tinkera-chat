{
  "name": "chat-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:chat\"",
    "dev:main": "next dev -p 3001",
    "dev:chat": "cd nextjs-chat && npm run dev -- --hostname 0.0.0.0 --port 3002",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.412.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "next-themes": "^0.3.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "concurrently": "^9.0.6"
  }
}